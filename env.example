<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1"/>
<title>☠️ One Piece RP — V3</title>
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Cinzel+Decorative:wght@700&family=Crimson+Text:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet"/>
<style>
/* ══════════════════════════════════════════════════════
   DESIGN SYSTEM
══════════════════════════════════════════════════════ */
:root{
  --bg:    #080b11; --bg2:#0e1420; --bg3:#131a28;
  --gold:  #c9a84c; --gold-l:#e8c97a; --gold-d:#7a5f1a;
  --blue:  #1e3a5f; --blue-l:#2d6ab4;
  --red:   #7f1d1d; --red-l:#ef4444;
  --green: #14532d; --green-l:#22c55e;
  --amber: #78350f; --amber-l:#f59e0b;
  --text:  #e2d9c8; --muted:#5a5345;
  --border:rgba(201,168,76,.15);
  --fc-pirate:#ef4444; --fc-marine:#3b82f6; --fc-secret:#8b5cf6; --fc-system:#c9a84c;
  --ft:'Cinzel Decorative',serif;
  --fh:'Cinzel',serif;
  --fb:'Crimson Text',serif;
  --r:8px;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{font-size:16px;height:100%}
body{
  background:var(--bg);color:var(--text);font-family:var(--fb);
  height:100%;display:flex;flex-direction:column;overflow:hidden;
  background-image:
    radial-gradient(ellipse at 15% 85%,rgba(30,58,95,.3) 0%,transparent 50%),
    radial-gradient(ellipse at 85% 10%,rgba(127,29,29,.2) 0%,transparent 45%);
}
::-webkit-scrollbar{width:4px;height:4px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--gold-d);border-radius:2px}
input,button,select,textarea{font-family:var(--fb)}

/* ══ OVERLAY AUTH ═════════════════════════════════════ */
#overlay{
  position:fixed;inset:0;z-index:200;
  background:var(--bg);
  display:flex;flex-direction:column;align-items:center;justify-content:center;gap:18px;
  background-image:radial-gradient(circle at 50% 40%,rgba(201,168,76,.07) 0%,transparent 55%);
}
.ov-icon{font-size:52px;animation:float 3s ease-in-out infinite}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-10px)}}
.ov-title{font-family:var(--ft);color:var(--gold);font-size:1.9em;letter-spacing:10px;text-align:center;line-height:1.3}
.ov-card{
  background:var(--bg2);border:1px solid var(--border);border-radius:14px;
  padding:28px 26px;width:min(340px,92vw);
  display:flex;flex-direction:column;gap:11px;
}
.ov-tabs{display:flex;gap:0;border-bottom:1px solid var(--border);margin-bottom:4px}
.ov-tab{
  flex:1;padding:8px;background:none;border:none;
  border-bottom:2px solid transparent;color:var(--muted);
  font-family:var(--fh);font-size:.65em;letter-spacing:2px;cursor:pointer;transition:.2s;
}
.ov-tab.active{border-bottom-color:var(--gold);color:var(--gold)}
.ov-err{min-height:1.1em;font-size:.78em;color:var(--red-l);text-align:center}

/* ══ INPUTS ═══════════════════════════════════════════ */
.inp{
  width:100%;background:rgba(255,255,255,.04);
  border:1px solid var(--border);border-radius:var(--r);
  padding:9px 12px;color:var(--text);font-size:.95em;outline:none;
  transition:border-color .2s;
}
.inp:focus{border-color:var(--gold)}
.inp::placeholder{color:var(--muted)}
select.inp{cursor:pointer;appearance:none}
select.inp option{background:var(--bg2)}

/* ══ BUTTONS ══════════════════════════════════════════ */
.btn{
  background:transparent;border:1px solid var(--gold);color:var(--gold);
  padding:9px 16px;border-radius:var(--r);cursor:pointer;
  font-family:var(--fh);font-size:.65em;letter-spacing:2px;
  transition:.2s;white-space:nowrap;text-align:center;
}
.btn:hover:not(:disabled){background:var(--gold);color:#000}
.btn:disabled{opacity:.2;cursor:not-allowed}
.btn-full{width:100%;display:block;padding:11px}
.btn-sm{padding:5px 11px;font-size:.6em}
.btn-danger{border-color:var(--red-l);color:var(--red-l)}
.btn-danger:hover:not(:disabled){background:var(--red-l);color:#fff}
.btn-green{border-color:var(--green-l);color:var(--green-l)}
.btn-green:hover:not(:disabled){background:var(--green-l);color:#000}

/* ══ APP SHELL ════════════════════════════════════════ */
#app{display:none;flex:1;flex-direction:column;overflow:hidden}
#app.on{display:flex}

/* ── Header ── */
#topbar{
  display:flex;align-items:center;gap:12px;
  padding:8px 18px;background:var(--bg2);
  border-bottom:1px solid var(--border);flex-shrink:0;
  position:relative;z-index:10;
}
.tb-logo{font-family:var(--ft);color:var(--gold);font-size:.8em;letter-spacing:3px;flex-shrink:0}
.tb-sep{width:1px;height:24px;background:var(--border);flex-shrink:0}
.tb-player{display:flex;align-items:center;gap:8px;flex:1;min-width:0}
.tb-name{font-family:var(--fh);font-size:.85em;color:var(--gold-l);overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.tb-grade{font-size:.7em;color:var(--muted);white-space:nowrap}
.faction-badge{
  padding:2px 9px;border-radius:20px;
  font-family:var(--fh);font-size:.58em;letter-spacing:2px;border:1px solid;flex-shrink:0;
}
.fb-pirate{color:var(--fc-pirate);border-color:rgba(239,68,68,.35);background:rgba(239,68,68,.08)}
.fb-marine{color:var(--fc-marine);border-color:rgba(59,130,246,.35);background:rgba(59,130,246,.08)}
.fb-secret{color:var(--fc-secret);border-color:rgba(139,92,246,.35);background:rgba(139,92,246,.08)}
.tb-online{margin-left:auto;font-family:var(--fh);font-size:.62em;color:var(--muted);white-space:nowrap;flex-shrink:0}

/* ── Burger menu (mobile) ── */
#burger{display:none;background:none;border:none;color:var(--gold);font-size:1.3em;cursor:pointer;padding:4px}

/* ══ LAYOUT ═══════════════════════════════════════════ */
#layout{display:flex;flex:1;overflow:hidden}

/* ── Left panel ── */
#left{
  width:240px;flex-shrink:0;background:var(--bg2);
  border-right:1px solid var(--border);
  overflow-y:auto;padding:16px 14px;
  display:flex;flex-direction:column;gap:12px;
  transition:transform .25s;
}

/* ── Center ── */
#center{flex:1;display:flex;flex-direction:column;overflow:hidden;background:var(--bg3)}
/* Tab bar */
#tab-bar{
  display:flex;gap:0;background:var(--bg2);
  border-bottom:1px solid var(--border);flex-shrink:0;
}
.tab-btn{
  flex:1;padding:10px 6px;background:none;border:none;
  border-bottom:2px solid transparent;color:var(--muted);
  font-family:var(--fh);font-size:.6em;letter-spacing:2px;cursor:pointer;
  transition:.2s;
}
.tab-btn.active{border-bottom-color:var(--gold);color:var(--gold)}
/* Tab content */
.tab-pane{display:none;flex:1;flex-direction:column;overflow:hidden}
.tab-pane.active{display:flex}

/* ── Right panel ── */
#right{
  width:220px;flex-shrink:0;background:var(--bg2);
  border-left:1px solid var(--border);
  overflow-y:auto;padding:14px 12px;
  display:flex;flex-direction:column;gap:10px;
}

/* ══ STAT PANEL ═══════════════════════════════════════ */
.sblock{
  background:rgba(201,168,76,.03);border:1px solid var(--border);
  border-radius:var(--r);padding:13px;
}
.sblock h3{
  font-family:var(--fh);font-size:.62em;letter-spacing:3px;
  color:var(--gold);margin-bottom:11px;text-transform:uppercase;
}
.srow{display:flex;justify-content:space-between;align-items:center;margin-bottom:7px}
.sk{font-size:.72em;color:var(--muted);letter-spacing:.5px}
.sv{font-family:var(--fh);font-size:.8em;color:var(--text)}
.sv.gold{color:var(--gold)}.sv.green{color:var(--green-l)}.sv.red{color:var(--red-l)}

.currency-row{display:flex;gap:8px;margin:6px 0 10px}
.cpill{
  flex:1;background:rgba(201,168,76,.06);
  border:1px solid var(--border);border-radius:6px;
  padding:8px 6px;text-align:center;
}
.cpill-val{font-family:var(--fh);font-size:.88em;color:var(--gold);transition:color .3s}
.cpill-lbl{font-size:.58em;letter-spacing:1.5px;color:var(--muted);margin-top:2px}

/* Grade bar */
.gbar-wrap{margin-top:6px}
.gbar-labels{display:flex;justify-content:space-between;font-size:.65em;color:var(--muted);margin-bottom:4px}
.gbar{height:4px;background:rgba(255,255,255,.06);border-radius:2px;overflow:hidden}
.gbar-fill{
  height:100%;border-radius:2px;
  background:linear-gradient(90deg,var(--gold-d),var(--gold));
  transition:width .7s cubic-bezier(.4,0,.2,1);
}

/* Wanted */
.wanted-dots{display:flex;gap:4px;margin-top:2px}
.wd{width:10px;height:10px;border-radius:50%;border:1px solid rgba(239,68,68,.3);transition:.3s}
.wd.on{background:var(--red-l);border-color:var(--red-l);box-shadow:0 0 5px var(--red-l)}

/* Prison banner */
.jail-banner{
  background:rgba(127,29,29,.25);border:1px solid rgba(239,68,68,.4);
  border-radius:6px;padding:10px;text-align:center;
  font-size:.78em;color:var(--red-l);
  animation:blink 1.2s ease-in-out infinite;
}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.55}}

/* Action buttons */
.actions-grid{display:grid;grid-template-columns:1fr 1fr;gap:7px}
.action-btn{
  background:rgba(255,255,255,.03);border:1px solid var(--border);
  border-radius:var(--r);padding:11px 6px;cursor:pointer;
  font-family:var(--fh);font-size:.6em;letter-spacing:1.5px;
  color:var(--text);text-align:center;transition:.2s;
  display:flex;flex-direction:column;align-items:center;gap:5px;
}
.action-btn .ai{font-size:1.5em;line-height:1}
.action-btn:hover:not(:disabled){border-color:var(--gold-d);background:rgba(201,168,76,.07);color:var(--gold)}
.action-btn.red:hover:not(:disabled){border-color:rgba(239,68,68,.5);background:rgba(239,68,68,.07);color:var(--red-l)}
.action-btn:disabled{opacity:.22;cursor:not-allowed}
/* Cooldown flash */
.action-btn.cd{animation:cdflash .6s ease}
@keyframes cdflash{0%,100%{opacity:1}50%{opacity:.3}}

/* Combat input */
.combat-wrap{display:none;margin-top:8px}
.combat-wrap.open{display:flex;gap:6px}

/* ══ LOG / JOURNAL ════════════════════════════════════ */
#log-pane{flex:1;overflow-y:auto;padding:12px 16px;display:flex;flex-direction:column;gap:5px}
.log-entry{
  padding:6px 11px;border-radius:5px;font-size:.87em;line-height:1.55;
  border-left:3px solid transparent;animation:lgin .2s ease;
}
@keyframes lgin{from{opacity:0;transform:translateX(-5px)}to{opacity:1;transform:none}}
.log-entry strong{font-family:var(--fh);font-size:.85em;letter-spacing:.5px}
.le-success{background:rgba(20,83,45,.2);border-left-color:var(--green-l);color:#86efac}
.le-warn   {background:rgba(120,53,15,.2);border-left-color:var(--amber-l);color:#fcd34d}
.le-danger {background:rgba(127,29,29,.25);border-left-color:var(--red-l);color:#fca5a5}
.le-info   {background:rgba(30,58,138,.2);border-left-color:var(--blue-l);color:#93c5fd}
.le-combat {background:rgba(88,28,135,.2);border-left-color:#a78bfa;color:#ddd6fe}

/* ══ CHAT ════════════════════════════════════════════ */
#chat-pane{flex:1;overflow-y:auto;padding:12px 16px;display:flex;flex-direction:column;gap:6px}
.chat-msg{animation:lgin .2s ease;line-height:1.55}
.cm-author{font-family:var(--fh);font-size:.72em;letter-spacing:1px;margin-right:6px}
.cm-text{font-size:.9em}
.cm-time{font-size:.65em;color:var(--muted);margin-left:6px}
.cm-sys{color:var(--gold);font-style:italic;font-size:.85em;padding:4px 0}
.cm-sys .cm-author{color:var(--gold)}
.chat-compose{
  display:flex;gap:8px;padding:10px 14px;
  background:var(--bg2);border-top:1px solid var(--border);flex-shrink:0;
}
.chat-ch{
  padding:5px 10px;border:1px solid var(--border);border-radius:20px;
  background:transparent;color:var(--muted);
  font-family:var(--fh);font-size:.58em;letter-spacing:1.5px;cursor:pointer;transition:.2s;flex-shrink:0;
}
.chat-ch.active{border-color:var(--gold);color:var(--gold);background:rgba(201,168,76,.07)}

/* ══ LEADERBOARD ═════════════════════════════════════ */
#lb-title{font-family:var(--fh);font-size:.68em;letter-spacing:3px;color:var(--gold);margin-bottom:12px;text-transform:uppercase}
.lb-row{
  display:flex;align-items:center;gap:7px;
  padding:7px 9px;margin-bottom:5px;
  border-radius:6px;background:rgba(255,255,255,.02);
  border:1px solid rgba(255,255,255,.04);
  cursor:pointer;transition:border-color .2s;
}
.lb-row:hover{border-color:var(--border)}
.lb-rank{font-family:var(--fh);font-size:.7em;color:var(--muted);width:18px;text-align:center;flex-shrink:0}
.lb-rank.g{color:#fbbf24}.lb-rank.s{color:#94a3b8}.lb-rank.b{color:#b45309}
.lb-info{flex:1;overflow:hidden}
.lb-name{font-family:var(--fh);font-size:.72em;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.lb-grade{font-size:.62em;color:var(--muted)}
.lb-bounty{font-size:.68em;font-family:var(--fh);color:var(--gold);white-space:nowrap}

/* ══ COMBAT HISTORY ══════════════════════════════════ */
#hist-pane{flex:1;overflow-y:auto;padding:12px 14px;display:flex;flex-direction:column;gap:8px}
.ch-card{
  background:rgba(88,28,135,.1);border:1px solid rgba(139,92,246,.2);
  border-radius:var(--r);padding:10px 13px;font-size:.82em;
}
.ch-header{display:flex;justify-content:space-between;font-family:var(--fh);font-size:.72em;color:#a78bfa;margin-bottom:6px}
.ch-line{color:var(--text);opacity:.8;margin-bottom:2px}

/* ══ ADMIN PANEL (inside right) ═══════════════════════ */
#admin-wrap{display:none}
.adm-block{
  background:rgba(139,92,246,.06);border:1px solid rgba(139,92,246,.2);
  border-radius:var(--r);padding:12px;
}
.adm-block h3{font-family:var(--fh);font-size:.62em;letter-spacing:2px;color:#a78bfa;margin-bottom:11px}
.adm-row{display:flex;gap:6px;margin-bottom:7px;flex-wrap:wrap}

/* ══ TOASTS ══════════════════════════════════════════ */
#toasts{position:fixed;bottom:14px;right:14px;z-index:999;display:flex;flex-direction:column;gap:5px;pointer-events:none}
.toast{
  padding:8px 14px;border-radius:6px;
  font-family:var(--fh);font-size:.62em;letter-spacing:1px;
  max-width:240px;animation:tin .3s ease;
  backdrop-filter:blur(8px);
}
.t-s{background:rgba(20,83,45,.9);color:#86efac;border:1px solid var(--green-l)}
.t-e{background:rgba(127,29,29,.9);color:#fca5a5;border:1px solid var(--red-l)}
.t-i{background:rgba(30,58,138,.9);color:#93c5fd;border:1px solid var(--blue-l)}
.t-w{background:rgba(120,53,15,.9);color:#fcd34d;border:1px solid var(--amber-l)}
@keyframes tin{from{transform:translateX(50px);opacity:0}to{transform:translateX(0);opacity:1}}

/* ══ RESPONSIVE ══════════════════════════════════════ */
@media(max-width:900px){
  #right{display:none}
}
@media(max-width:640px){
  #burger{display:block}
  #left{
    position:fixed;top:0;left:0;bottom:0;
    width:240px;z-index:100;
    transform:translateX(-100%);
    box-shadow:4px 0 20px rgba(0,0,0,.5);
  }
  #left.open{transform:translateX(0)}
  #left-overlay{
    display:none;position:fixed;inset:0;z-index:99;
    background:rgba(0,0,0,.6);
  }
  #left.open ~ #left-overlay{display:block}
  .tb-logo{font-size:.7em;letter-spacing:2px}
  .tb-online{display:none}
}
</style>
</head>
<body>

<!-- ══ AUTH ══════════════════════════════════════════════ -->
<div id="overlay">
  <div class="ov-icon">☠️</div>
  <div class="ov-title">ONE PIECE RP<br><span style="font-size:.5em;letter-spacing:6px;opacity:.7">VERSION 3</span></div>
  <div class="ov-card">
    <div class="ov-tabs">
      <button class="ov-tab active" id="tab-login-btn"    onclick="switchTab('login')">CONNEXION</button>
      <button class="ov-tab"        id="tab-register-btn" onclick="switchTab('register')">INSCRIPTION</button>
    </div>

    <!-- Login -->
    <div id="tab-login">
      <input class="inp" id="l-name" placeholder="Votre nom" maxlength="28" onkeydown="if(event.key==='Enter')tryLogin()"/>
      <input class="inp" id="l-pass" type="password" placeholder="Mot de passe" onkeydown="if(event.key==='Enter')tryLogin()"/>
      <button class="btn btn-full" onclick="tryLogin()">PRENDRE LA MER</button>
    </div>

    <!-- Register -->
    <div id="tab-register" style="display:none">
      <input class="inp" id="r-name"    placeholder="Choisissez un nom" maxlength="28"/>
      <input class="inp" id="r-pass"    type="password" placeholder="Mot de passe (min. 4 car.)"/>
      <select class="inp" id="r-faction">
        <option value="pirate">🏴‍☠️ Pirate</option>
        <option value="marine">⚓ Marine</option>
      </select>
      <input class="inp" id="r-admin"   type="password" placeholder="Code secret (optionnel)"/>
      <button class="btn btn-full" onclick="tryRegister()">CRÉER LE PERSONNAGE</button>
    </div>

    <div class="ov-err" id="auth-err"></div>
  </div>
</div>

<!-- ══ APP ════════════════════════════════════════════════ -->
<div id="app">

  <!-- Topbar -->
  <div id="topbar">
    <button id="burger" onclick="toggleLeft()">☰</button>
    <div class="tb-logo">☠️ GRAND LINE</div>
    <div class="tb-sep"></div>
    <div class="tb-player">
      <div>
        <div class="tb-name" id="tb-name">—</div>
        <div class="tb-grade" id="tb-grade">—</div>
      </div>
      <div class="faction-badge" id="tb-badge">—</div>
    </div>
    <div class="tb-online" id="tb-online">0 en ligne</div>
  </div>

  <div id="layout">

    <!-- ══ LEFT ══ -->
    <div id="left">

      <!-- Prison -->
      <div class="jail-banner" id="jail-banner" style="display:none">
        ⛓️ EN PRISON<br>
        <span id="jail-timer" style="font-family:var(--fh);font-size:.95em">30s</span>
        <button class="btn btn-sm btn-danger btn-full" onclick="tryRelease()" style="margin-top:7px">Tenter la sortie</button>
      </div>

      <!-- Stats -->
      <div class="sblock">
        <h3>Statistiques</h3>
        <div class="currency-row">
          <div class="cpill"><div class="cpill-val" id="s-bounty">0</div><div class="cpill-lbl">PRIME ฿</div></div>
          <div class="cpill"><div class="cpill-val" id="s-berries">0</div><div class="cpill-lbl">BERRYS</div></div>
        </div>
        <div class="srow"><span class="sk">XP</span><span class="sv" id="s-xp">0</span></div>
        <div class="srow">
          <span class="sk">Wanted</span>
          <div class="wanted-dots" id="wanted-dots">
            <div class="wd"></div><div class="wd"></div><div class="wd"></div>
          </div>
        </div>
        <div class="gbar-wrap">
          <div class="gbar-labels"><span id="g-cur">—</span><span id="g-next" style="opacity:.5">→ ?</span></div>
          <div class="gbar"><div class="gbar-fill" id="g-fill" style="width:0%"></div></div>
        </div>
      </div>

      <!-- Actions -->
      <div class="sblock">
        <h3>Actions</h3>
        <div class="actions-grid">
          <button class="action-btn" id="btn-train"    onclick="act('train')">    <span class="ai">💪</span>S'ENTRAÎNER</button>
          <button class="action-btn red" id="btn-pillage" onclick="act('pillage')"><span class="ai">🏴‍☠️</span>PILLER</button>
          <button class="action-btn" id="btn-navigate"  onclick="act('navigate')"><span class="ai">⛵</span>NAVIGUER</button>
          <button class="action-btn red" id="btn-combat"  onclick="toggleCombat()"><span class="ai">⚔️</span>COMBATTRE</button>
        </div>
        <div class="combat-wrap" id="combat-wrap">
          <input class="inp" id="combat-target" placeholder="Nom de l'adversaire" style="font-size:.85em"/>
          <button class="btn btn-sm" onclick="startCombat()">GO</button>
        </div>
      </div>

      <!-- Stats détaillées -->
      <div class="sblock" id="stats-detail">
        <h3>Statistiques</h3>
        <div class="srow"><span class="sk">Entraînements</span><span class="sv" id="sd-train">0</span></div>
        <div class="srow"><span class="sk">Pillages</span><span class="sv" id="sd-pillage">0</span></div>
        <div class="srow"><span class="sk">Navigations</span><span class="sv" id="sd-nav">0</span></div>
        <div class="srow"><span class="sk">Victoires</span><span class="sv green" id="sd-wins">0</span></div>
        <div class="srow"><span class="sk">Défaites</span><span class="sv red" id="sd-losses">0</span></div>
        <div class="srow"><span class="sk">Arrestations</span><span class="sv" id="sd-arrested">0</span></div>
      </div>

      <!-- Admin -->
      <div id="admin-wrap" style="display:none">
        <div class="adm-block">
          <h3>⚙️ ADMIN</h3>
          <input class="inp" id="a-target"  placeholder="Joueur cible" style="margin-bottom:6px;font-size:.85em"/>
          <input class="inp" id="a-value"   placeholder="Valeur" style="margin-bottom:6px;font-size:.85em"/>
          <input class="inp" id="a-code"    type="password" placeholder="Code admin" style="margin-bottom:8px;font-size:.85em"/>
          <div class="adm-row">
            <button class="btn btn-sm" onclick="admDo('setBounty')" style="flex:1">Prime</button>
            <button class="btn btn-sm" onclick="admDo('setBerries')" style="flex:1">Berrys</button>
          </div>
          <div class="adm-row">
            <button class="btn btn-sm" onclick="admDo('release')" style="flex:1">Libérer</button>
            <button class="btn btn-sm" onclick="admDo('mute')" style="flex:1">Mute</button>
          </div>
          <div class="adm-row">
            <button class="btn btn-sm btn-danger" onclick="admDo('ban')" style="flex:1">Bannir</button>
            <button class="btn btn-sm" onclick="admDo('resetStats')" style="flex:1">Reset</button>
          </div>
          <div style="margin-top:6px">
            <input class="inp" id="a-broadcast" placeholder="Message broadcast..." style="margin-bottom:6px;font-size:.85em"/>
            <button class="btn btn-sm btn-full" onclick="admBroadcast()">Diffuser</button>
          </div>
        </div>
      </div>

    </div>
    <div id="left-overlay" onclick="toggleLeft()"></div>

    <!-- ══ CENTER ══ -->
    <div id="center">
      <div id="tab-bar">
        <button class="tab-btn active" onclick="showTab('log')">📒 JOURNAL</button>
        <button class="tab-btn" onclick="showTab('chat')">💬 CHAT</button>
        <button class="tab-btn" onclick="showTab('hist')">⚔️ COMBATS</button>
      </div>

      <!-- Journal de bord -->
      <div class="tab-pane active" id="pane-log" style="flex-direction:column">
        <div id="log-pane"></div>
        <div style="padding:6px 14px;border-top:1px solid var(--border);display:flex;justify-content:flex-end;flex-shrink:0">
          <button class="btn btn-sm" onclick="clearLog()" style="opacity:.4;font-size:.55em">EFFACER</button>
        </div>
      </div>

      <!-- Chat -->
      <div class="tab-pane" id="pane-chat" style="flex-direction:column">
        <div id="chat-pane"></div>
        <div class="chat-compose">
          <div style="display:flex;gap:5px;flex-shrink:0">
            <button class="chat-ch active" id="ch-global" onclick="setCh('global',this)">GLOBAL</button>
            <button class="chat-ch" id="ch-faction" onclick="setCh('faction',this)">FACTION</button>
          </div>
          <input class="inp" id="chat-input" placeholder="Votre message..." maxlength="500" style="flex:1;margin:0;font-size:.88em" onkeydown="if(event.key==='Enter')sendChat()"/>
          <button class="btn btn-sm" onclick="sendChat()">ENVOYER</button>
        </div>
      </div>

      <!-- Historique combats -->
      <div class="tab-pane" id="pane-hist" style="flex-direction:column">
        <div id="hist-pane"></div>
        <div style="padding:8px 14px;border-top:1px solid var(--border);flex-shrink:0">
          <button class="btn btn-sm" onclick="loadCombatHistory()">↻ Actualiser</button>
        </div>
      </div>
    </div>

    <!-- ══ RIGHT ══ -->
    <div id="right">
      <div id="lb-title">🏆 Classement</div>
      <div id="lb-list"></div>
    </div>

  </div>
</div>

<div id="toasts"></div>

<!-- Sons via Web Audio API (pas de fichiers externes) -->
<script>
// ══════════════════════════════════════════════════════════
//  AUDIO
// ══════════════════════════════════════════════════════════
let _ac = null;
function getAC() { if (!_ac) _ac = new (window.AudioContext || window.webkitAudioContext)(); return _ac; }

function playTone(freq, dur, type='sine', vol=.08) {
  try {
    const ac  = getAC();
    const osc = ac.createOscillator();
    const gain= ac.createGain();
    osc.connect(gain); gain.connect(ac.destination);
    osc.type = type; osc.frequency.value = freq;
    gain.gain.setValueAtTime(vol, ac.currentTime);
    gain.gain.exponentialRampToValueAtTime(0.001, ac.currentTime + dur);
    osc.start(); osc.stop(ac.currentTime + dur);
  } catch {}
}
const SFX = {
  success: () => { playTone(440,.1); setTimeout(()=>playTone(660,.15),100); },
  fail:    () => { playTone(220,.2,'sawtooth',.06); },
  combat:  () => { [200,300,250].forEach((f,i)=>setTimeout(()=>playTone(f,.1,'square',.05),i*80)); },
  join:    () => { playTone(330,.1); setTimeout(()=>playTone(550,.2),120); },
  jailed:  () => { [400,300,200].forEach((f,i)=>setTimeout(()=>playTone(f,.12,'sawtooth',.07),i*90)); },
};

// ══════════════════════════════════════════════════════════
//  STATE
// ══════════════════════════════════════════════════════════
let socket   = null;
let me       = {};
let authTab  = 'login';
let chatCh   = 'global';
let combatOpen = false;
let jailInterval = null;
let cdUntil  = 0;

// ── Grades miroir ─
const GRADES = {
  pirate: [{l:'Mousse',t:0},{l:'Pirate',t:5000},{l:'Pirate Notoire',t:50000},{l:'Supernova',t:300000},{l:'Capitaine',t:1000000},{l:'Shichibukai',t:10000000},{l:'Yonko',t:100000000}],
  marine: [{l:'Matelot',t:0},{l:'Enseigne',t:10000},{l:'Lieutenant',t:50000},{l:'Capitaine',t:200000},{l:'Commodore',t:500000},{l:'Vice-Amiral',t:2000000},{l:'Amiral',t:10000000}],
  secret: [{l:'Agent Secret',t:0},{l:'Amiral de la Flotte',t:0}],
};

// ══════════════════════════════════════════════════════════
//  UTILS
// ══════════════════════════════════════════════════════════
const fmt = n=>{
  n=Math.max(0,Math.floor(n||0));
  if(n>=1e9) return (n/1e9).toFixed(2)+'Md';
  if(n>=1e6) return (n/1e6).toFixed(1)+'M';
  if(n>=1e3) return (n/1e3).toFixed(0)+'k';
  return String(n);
};
const fmtFull = n => Math.max(0,Math.floor(n||0)).toLocaleString('fr-FR');

function toast(msg,type='i'){
  const el=document.createElement('div');
  el.className=`toast t-${type}`;el.textContent=msg;
  document.getElementById('toasts').appendChild(el);
  setTimeout(()=>el.remove(),3000);
}

function md(t){return String(t).replace(/\*\*(.*?)\*\*/g,'<strong>$1</strong>')}

// ══════════════════════════════════════════════════════════
//  AUTH UI
// ══════════════════════════════════════════════════════════
function switchTab(t){
  authTab=t;
  document.getElementById('tab-login').style.display     = t==='login'?'':'none';
  document.getElementById('tab-register').style.display  = t==='register'?'':'none';
  document.getElementById('tab-login-btn').classList.toggle('active',t==='login');
  document.getElementById('tab-register-btn').classList.toggle('active',t==='register');
  document.getElementById('auth-err').textContent='';
}

function setAuthErr(msg){ document.getElementById('auth-err').textContent=msg; }

function tryLogin(){
  const name=document.getElementById('l-name').value.trim();
  const pass=document.getElementById('l-pass').value;
  if(!name||!pass){setAuthErr('Remplissez tous les champs');return;}
  initSocket();
  socket.emit('auth:login',{name,password:pass});
}

function tryRegister(){
  const name=document.getElementById('r-name').value.trim();
  const pass=document.getElementById('r-pass').value;
  const fact=document.getElementById('r-faction').value;
  const code=document.getElementById('r-admin').value;
  if(!name||!pass){setAuthErr('Remplissez tous les champs');return;}
  if(pass.length<4){setAuthErr('Mot de passe trop court (min. 4)');return;}
  initSocket();
  socket.emit('auth:register',{name,password:pass,faction:fact,adminCode:code});
}

function tryToken(){
  const token=localStorage.getItem('op_token');
  const name =localStorage.getItem('op_name');
  if(!token||!name) return false;
  initSocket();
  socket.emit('auth:token',{name,token});
  return true;
}

// ══════════════════════════════════════════════════════════
//  SOCKET
// ══════════════════════════════════════════════════════════
function initSocket(){
  if(socket) return;
  socket=io({transports:['websocket','polling']});

  socket.on('connect',    ()=>{ if(!me.name) tryToken(); });
  socket.on('disconnect', ()=>toast('Connexion perdue','e'));

  socket.on('auth:error', msg=>{
    setAuthErr(msg);
    toast(msg,'e');
    SFX.fail();
  });

  socket.on('auth:success',({token,player})=>{
    localStorage.setItem('op_token', token);
    localStorage.setItem('op_name',  player.name);
    me = player;
    document.getElementById('overlay').style.display='none';
    document.getElementById('app').classList.add('on');
    renderPlayer(player);
    SFX.join();
    loadCombatHistory();
  });

  socket.on('player:update', p=>{
    me=p;
    renderPlayer(p);
  });

  socket.on('log:add', ({type,msg})=>{
    addLog(type,msg);
    if(type==='success') SFX.success();
    if(type==='danger')  SFX.fail();
    if(type==='combat')  SFX.combat();
    if(msg.includes('prison')||msg.includes('ARRÊTÉ')) SFX.jailed();
  });

  socket.on('chat:history', msgs=>{
    document.getElementById('chat-pane').innerHTML='';
    msgs.forEach(renderChatMsg);
  });

  socket.on('chat:message', msg=>{
    renderChatMsg(msg);
    // Si pas sur l'onglet chat, badge
    if(!document.getElementById('pane-chat').classList.contains('active')){
      const btn=document.querySelector('[onclick="showTab(\'chat\')"]');
      if(btn&&!msg.isSystem) btn.style.color='var(--gold)';
    }
  });

  socket.on('leaderboard:update', list=>{
    renderLeaderboard(list);
    const n=list.filter(p=>onlineSet.has(p.name)).length;
    document.getElementById('tb-online').textContent=`${onlineCount} en ligne`;
  });

  socket.on('online:update', users=>{
    onlineCount=users.length;
    onlineSet=new Set(users.map(u=>u.name));
    document.getElementById('tb-online').textContent=`${onlineCount} en ligne`;
  });

  socket.on('action:cooldown', ms=>{
    toast('⏳ Attendez un instant...','w');
    cdUntil=Date.now()+ms;
    setActionBtns(true);
    setTimeout(()=>setActionBtns(me.isJailed||false),ms);
  });
}

let onlineCount=0, onlineSet=new Set();

// ══════════════════════════════════════════════════════════
//  RENDER PLAYER
// ══════════════════════════════════════════════════════════
const animVals={};
function animNum(id,target){
  const el=document.getElementById(id);
  if(!el) return;
  const from=animVals[id]||0; animVals[id]=target;
  const start=performance.now(), dur=600, startV=from;
  const step=now=>{
    const t=Math.min(1,(now-start)/dur);
    const e=t<.5?2*t*t:-1+(4-2*t)*t;
    el.textContent=fmt(Math.floor(startV+(target-startV)*e));
    if(t<1) requestAnimationFrame(step);
    else el.textContent=fmt(target);
  };
  requestAnimationFrame(step);
}

function renderPlayer(p){
  // Header
  document.getElementById('tb-name').textContent=p.name||'—';
  document.getElementById('tb-grade').textContent=p.grade||'—';
  const badge=document.getElementById('tb-badge');
  badge.textContent=(p.faction||'').toUpperCase();
  badge.className=`faction-badge fb-${p.faction||'pirate'}`;

  // Stats animées
  animNum('s-bounty',  p.bounty  ||0);
  animNum('s-berries', p.berries ||0);
  document.getElementById('s-xp').textContent=fmtFull(p.xp||0);

  // Wanted dots
  const wl=p.wantedLevel||0;
  document.querySelectorAll('.wd').forEach((d,i)=>d.classList.toggle('on',i<wl));

  // Grade bar
  const grades=GRADES[p.faction]||GRADES.pirate;
  const idx=p.gradeIndex||0;
  const cur=grades[idx], next=grades[idx+1];
  const stat=p.faction==='marine'?p.berries:p.bounty;
  let pct=100;
  if(next){
    const range=next.t-cur.t, prog=stat-cur.t;
    pct=Math.min(100,Math.max(0,Math.round((prog/range)*100)));
  }
  document.getElementById('g-cur').textContent=cur?.l||p.grade||'—';
  document.getElementById('g-next').textContent=next?`→ ${next.l}`:'★ MAX';
  document.getElementById('g-fill').style.width=pct+'%';

  // Stats détaillées
  const st=p.stats||{};
  document.getElementById('sd-train').textContent   =st.trainCount  ||0;
  document.getElementById('sd-pillage').textContent =st.pillageCount ||0;
  document.getElementById('sd-nav').textContent     =st.navCount     ||0;
  document.getElementById('sd-wins').textContent    =st.combatWins   ||0;
  document.getElementById('sd-losses').textContent  =st.combatLosses ||0;
  document.getElementById('sd-arrested').textContent=st.arrested      ||0;

  // Prison
  const jail=document.getElementById('jail-banner');
  if(p.isJailed&&p.jailUntil){
    jail.style.display='';
    setActionBtns(true);
    startJailTimer(new Date(p.jailUntil));
  } else {
    jail.style.display='none';
    clearJailTimer();
    setActionBtns(false);
  }

  // Admin
  if(p.adminLevel>=2) document.getElementById('admin-wrap').style.display='';
}

function setActionBtns(disabled){
  ['btn-train','btn-pillage','btn-navigate','btn-combat'].forEach(id=>{
    const b=document.getElementById(id);
    if(b) b.disabled=disabled;
  });
}

function startJailTimer(until){
  clearJailTimer();
  const tick=()=>{
    const s=Math.max(0,Math.ceil((until-Date.now())/1000));
    document.getElementById('jail-timer').textContent=s+'s';
    if(s<=0){ clearJailTimer(); socket.emit('action:release'); }
  };
  tick();
  jailInterval=setInterval(tick,1000);
}
function clearJailTimer(){ if(jailInterval){clearInterval(jailInterval);jailInterval=null;} }

// ══════════════════════════════════════════════════════════
//  ACTIONS
// ══════════════════════════════════════════════════════════
function act(type){
  if(Date.now()<cdUntil){toast('⏳ Cooldown...','w');return;}
  socket.emit(`action:${type}`);
  cdUntil=Date.now()+3200;
  setActionBtns(true);
  setTimeout(()=>setActionBtns(me?.isJailed||false),3200);
}

function toggleCombat(){
  combatOpen=!combatOpen;
  const w=document.getElementById('combat-wrap');
  w.classList.toggle('open',combatOpen);
  if(combatOpen) document.getElementById('combat-target').focus();
}

function startCombat(){
  const t=document.getElementById('combat-target').value.trim();
  if(!t){toast('Entrez un nom','e');return;}
  if(Date.now()<cdUntil){toast('⏳ Cooldown...','w');return;}
  socket.emit('action:combat',{target:t});
  document.getElementById('combat-target').value='';
  document.getElementById('combat-wrap').classList.remove('open');
  combatOpen=false;
  cdUntil=Date.now()+4000;
}

function tryRelease(){ socket.emit('action:release'); }

// ══════════════════════════════════════════════════════════
//  LOG
// ══════════════════════════════════════════════════════════
function addLog(type,msg){
  const pane=document.getElementById('log-pane');
  const div=document.createElement('div');
  div.className=`log-entry le-${type}`;
  div.innerHTML=md(msg);
  pane.appendChild(div);
  pane.scrollTop=pane.scrollHeight;
  while(pane.children.length>200) pane.removeChild(pane.firstChild);
}
function clearLog(){ document.getElementById('log-pane').innerHTML=''; }

// ══════════════════════════════════════════════════════════
//  CHAT
// ══════════════════════════════════════════════════════════
const FC_COLOR={pirate:'var(--fc-pirate)',marine:'var(--fc-marine)',secret:'var(--fc-secret)',system:'var(--fc-system)'};

function renderChatMsg(msg){
  const pane=document.getElementById('chat-pane');
  const div=document.createElement('div');
  div.className='chat-msg';
  const time=new Date(msg.createdAt||Date.now()).toLocaleTimeString('fr-FR',{hour:'2-digit',minute:'2-digit'});
  if(msg.isSystem){
    div.className+=' cm-sys';
    div.innerHTML=`<span class="cm-author" style="color:var(--fc-system)">SYSTÈME</span><span class="cm-text">${md(msg.text)}</span>`;
  } else {
    const c=FC_COLOR[msg.faction]||'var(--text)';
    div.innerHTML=`<span class="cm-author" style="color:${c}">${msg.author}</span><span class="cm-text">${md(msg.text)}</span><span class="cm-time">${time}</span>`;
  }
  pane.appendChild(div);
  pane.scrollTop=pane.scrollHeight;
  while(pane.children.length>300) pane.removeChild(pane.firstChild);
}

function setCh(ch,btn){
  chatCh=ch;
  document.querySelectorAll('.chat-ch').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
}

function sendChat(){
  const inp=document.getElementById('chat-input');
  const text=inp.value.trim();
  if(!text||!socket||!me.name) return;
  const channel=chatCh==='faction'?me.faction:'global';
  socket.emit('chat:send',{text,channel});
  inp.value='';
}

// ══════════════════════════════════════════════════════════
//  LEADERBOARD
// ══════════════════════════════════════════════════════════
function renderLeaderboard(list){
  const medals=[{cl:'g',t:'🥇'},{cl:'s',t:'🥈'},{cl:'b',t:'🥉'}];
  const fc={pirate:'var(--fc-pirate)',marine:'var(--fc-marine)',secret:'var(--fc-secret)'};
  document.getElementById('lb-list').innerHTML=list.map((p,i)=>`
    <div class="lb-row" onclick="fillCombatTarget('${p.name}')">
      <span class="lb-rank ${medals[i]?.cl||''}">${i<3?medals[i].t:'#'+(i+1)}</span>
      <div class="lb-info">
        <div class="lb-name" style="color:${fc[p.faction]||'var(--text)'}">${p.name}</div>
        <div class="lb-grade">${p.grade||'—'}</div>
      </div>
      <span class="lb-bounty">${fmt(p.bounty)} ฿</span>
    </div>`).join('');
}

function fillCombatTarget(name){
  document.getElementById('combat-target').value=name;
  if(!combatOpen) toggleCombat();
  document.getElementById('combat-target').focus();
}

// ══════════════════════════════════════════════════════════
//  COMBAT HISTORY
// ══════════════════════════════════════════════════════════
async function loadCombatHistory(){
  try{
    const r=await fetch('/api/combats');
    const list=await r.json();
    const pane=document.getElementById('hist-pane');
    if(!list.length){pane.innerHTML='<div style="color:var(--muted);padding:20px;font-style:italic;font-size:.85em">Aucun combat enregistré.</div>';return;}
    pane.innerHTML=list.map(c=>{
      const date=new Date(c.createdAt).toLocaleDateString('fr-FR',{day:'numeric',month:'short',hour:'2-digit',minute:'2-digit'});
      return `<div class="ch-card">
        <div class="ch-header"><span>⚔️ ${c.attacker} vs ${c.defender}</span><span>${date}</span></div>
        <div class="ch-line">🏆 Vainqueur : <strong>${c.winner}</strong> (+${(c.bountyGained||0).toLocaleString()} ฿)</div>
        ${(c.narrative||[]).slice(-2).map(l=>`<div class="ch-line" style="opacity:.65;font-size:.85em">${md(l)}</div>`).join('')}
      </div>`;
    }).join('');
  } catch { document.getElementById('hist-pane').innerHTML='<div style="color:var(--muted);padding:20px">Impossible de charger.</div>'; }
}

// ══════════════════════════════════════════════════════════
//  TABS / NAV
// ══════════════════════════════════════════════════════════
function showTab(id){
  document.querySelectorAll('.tab-pane').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b=>{b.classList.remove('active');b.style.color='';});
  document.getElementById('pane-'+id).classList.add('active');
  event.currentTarget?.classList.add('active');
  if(id==='hist') loadCombatHistory();
}

function toggleLeft(){
  document.getElementById('left').classList.toggle('open');
}

// ══════════════════════════════════════════════════════════
//  ADMIN
// ══════════════════════════════════════════════════════════
function admDo(action){
  const target=document.getElementById('a-target').value.trim();
  const value =document.getElementById('a-value').value.trim();
  const code  =document.getElementById('a-code').value.trim();
  socket.emit('admin:action',{action,target,value,code});
}
function admBroadcast(){
  const msg=document.getElementById('a-broadcast').value.trim();
  const code=document.getElementById('a-code').value.trim();
  if(!msg) return;
  socket.emit('admin:action',{action:'broadcast',value:msg,code});
  document.getElementById('a-broadcast').value='';
}

// ══════════════════════════════════════════════════════════
//  BOOT
// ══════════════════════════════════════════════════════════
window.addEventListener('load',()=>{
  // Tentative de reconnexion automatique par token
  const token=localStorage.getItem('op_token');
  const name =localStorage.getItem('op_name');
  if(token&&name){
    initSocket();
    // auth:token est émis dans le handler 'connect'
  }
});
</script>
</body>
</html>
